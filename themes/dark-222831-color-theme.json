{
  "$schema": "vscode://schemas/color-theme",
  "name": "Horizon 222831 Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#222831",
    "editor.foreground": "#F2F2F2",
    "editor.lineHighlightBackground": "#BFC9D11A",
    "editor.lineHighlightBorder": "#00000000",
    "editorLineNumber.foreground": "#BFC9D180",
    "editorLineNumber.activeForeground": "#F2F2F2",
    "editorCursor.foreground": "#4D96FF",
    "editor.selectionBackground": "#4D96FF40",
    "editor.inactiveSelectionBackground": "#4D96FF26",
    "editor.wordHighlightBackground": "#6BCB7730",
    "editor.wordHighlightStrongBackground": "#FFD93D30",
    "editor.findMatchBackground": "#FF6B6B66",
    "editor.findMatchHighlightBackground": "#FF6B6B30",
    "editorBracketMatch.background": "#6BCB7720",
    "editorBracketMatch.border": "#6BCB77",
    "editorBracketHighlight.foreground1": "#FFD166",
    "editorBracketHighlight.foreground2": "#06D6A0",
    "editorBracketHighlight.foreground3": "#118AB2",
    "editorBracketHighlight.foreground4": "#EF476F",
    "editorBracketHighlight.foreground5": "#9B5DE5",
    "editorBracketHighlight.foreground6": "#F15BB5",
    "editorBracketPairGuide.activeBackground1": "#FFD16699",
    "editorBracketPairGuide.activeBackground2": "#06D6A099",
    "editorBracketPairGuide.activeBackground3": "#118AB299",
    "editorBracketPairGuide.activeBackground4": "#EF476F99",
    "editorBracketPairGuide.activeBackground5": "#9B5DE599",
    "editorBracketPairGuide.activeBackground6": "#F15BB599",
    "editorBracketPairGuide.background1": "#FFD16626",
    "editorBracketPairGuide.background2": "#06D6A026",
    "editorBracketPairGuide.background3": "#118AB226",
    "editorBracketPairGuide.background4": "#EF476F26",
    "editorBracketPairGuide.background5": "#9B5DE526",
    "editorBracketPairGuide.background6": "#F15BB526",
    "editorIndentGuide.background1": "#BFC9D122",
    "editorIndentGuide.activeBackground1": "#4D96FF55",
    "editorWhitespace.foreground": "#BFC9D126",
    "editorOverviewRuler.border": "#00000000",
    "editorHoverWidget.background": "#1A2028",
    "editorHoverWidget.foreground": "#F2F2F2",
    "editorHoverWidget.border": "#44444E",
    "editorSuggestWidget.background": "#1A2028",
    "editorSuggestWidget.foreground": "#F2F2F2",
    "editorSuggestWidget.selectedBackground": "#4D96FF26",
    "editorSuggestWidget.highlightForeground": "#FFD93D",
    "editorSuggestWidget.border": "#44444E",
    "editorWidget.background": "#1A2028",
    "editorWidget.border": "#44444E",
    "editorGroupHeader.tabsBackground": "#1A2028",
    "editorGroup.border": "#44444E",
    "editorGroupHeader.border": "#44444E",
    "editorLink.activeForeground": "#6BCB77",
    "editorCodeLens.foreground": "#BFC9D199",
    "editorRuler.foreground": "#BFC9D122",
    "peekView.border": "#4D96FF",
    "peekViewEditor.background": "#1E242D",
    "peekViewResult.background": "#1A2028",
    "peekViewTitle.background": "#1A2028",
    "peekViewResult.selectionBackground": "#4D96FF26",
    "peekViewResult.matchHighlightBackground": "#FFD93D30",
    "minimap.background": "#1E242D",
    "minimap.selectionHighlight": "#4D96FF30",
    "minimap.findMatchHighlight": "#FF6B6B55",
    "minimap.errorHighlight": "#E62727",
    "minimap.warningHighlight": "#FFD93D",
    "minimapGutter.addedBackground": "#A6B28B",
    "minimapGutter.modifiedBackground": "#465C88",
    "minimapGutter.deletedBackground": "#B9375D",

    "activityBar.background": "#1C222B",
    "activityBar.foreground": "#F2F2F2",
    "activityBar.inactiveForeground": "#BFC9D1B3",
    "activityBarBadge.background": "#FF6B6B",
    "activityBarBadge.foreground": "#222831",
    "activityBar.border": "#44444E",

    "sideBar.background": "#1E242D",
    "sideBar.foreground": "#F2F2F2",
    "sideBar.border": "#44444E",
    "sideBarSectionHeader.background": "#1A2028",
    "sideBarSectionHeader.foreground": "#F2F2F2",
    "sideBarTitle.foreground": "#F2F2F2",

    "titleBar.activeBackground": "#1A2028",
    "titleBar.activeForeground": "#F2F2F2",
    "titleBar.inactiveBackground": "#1A2028CC",
    "titleBar.inactiveForeground": "#BFC9D1B3",

    "statusBar.background": "#1A2028",
    "statusBar.foreground": "#F2F2F2",
    "statusBar.debuggingBackground": "#FF6B6B",
    "statusBar.debuggingForeground": "#222831",
    "statusBar.noFolderBackground": "#1A2028",
    "statusBarItem.hoverBackground": "#BFC9D11A",

    "panel.background": "#1E242D",
    "panel.border": "#44444E",
    "panelTitle.activeForeground": "#F2F2F2",
    "panelTitle.inactiveForeground": "#BFC9D1B3",

    "tab.activeBackground": "#222831",
    "tab.activeForeground": "#F2F2F2",
    "tab.inactiveBackground": "#1A2028",
    "tab.inactiveForeground": "#BFC9D1B3",
    "tab.border": "#44444E",
    "tab.activeBorder": "#4D96FF",
    "tab.activeBorderTop": "#4D96FF",
    "tab.hoverBackground": "#252D38",
    "tab.unfocusedActiveForeground": "#F2F2F2CC",

    "list.activeSelectionBackground": "#4D96FF40",
    "list.activeSelectionForeground": "#F2F2F2",
    "list.hoverBackground": "#BFC9D11A",
    "list.highlightForeground": "#FFD93D",
    "list.focusOutline": "#4D96FF",

    "button.background": "#4D96FF",
    "button.foreground": "#F2F2F2",
    "button.hoverBackground": "#3D86EF",

    "input.background": "#1A2028",
    "input.foreground": "#F2F2F2",
    "input.border": "#44444E",
    "focusBorder": "#4D96FF",

    "dropdown.background": "#1A2028",
    "dropdown.foreground": "#F2F2F2",
    "dropdown.border": "#44444E",

    "breadcrumb.foreground": "#BFC9D1CC",
    "breadcrumb.activeSelectionForeground": "#F2F2F2",
    "breadcrumb.focusForeground": "#FFD93D",

    "scrollbarSlider.background": "#BFC9D126",
    "scrollbarSlider.hoverBackground": "#BFC9D140",
    "scrollbarSlider.activeBackground": "#BFC9D155",

    "terminal.background": "#222831",
    "terminal.foreground": "#F2F2F2",
    "terminal.ansiBlack": "#1A2028",
    "terminal.ansiRed": "#FF6B6B",
    "terminal.ansiGreen": "#6BCB77",
    "terminal.ansiYellow": "#FFD93D",
    "terminal.ansiBlue": "#4D96FF",
    "terminal.ansiMagenta": "#BB8ED0",
    "terminal.ansiCyan": "#ABDADC",
    "terminal.ansiWhite": "#F2F2F2",
    "terminal.ansiBrightBlack": "#BFC9D1",
    "terminal.ansiBrightRed": "#FF8B8B",
    "terminal.ansiBrightGreen": "#8BE196",
    "terminal.ansiBrightYellow": "#FFE36B",
    "terminal.ansiBrightBlue": "#76B0FF",
    "terminal.ansiBrightMagenta": "#C9A4E0",
    "terminal.ansiBrightCyan": "#C2E8EA",
    "terminal.ansiBrightWhite": "#FFFFFF",

    "notificationCenter.border": "#44444E",
    "notifications.background": "#1A2028",
    "notifications.foreground": "#F2F2F2",
    "notifications.border": "#44444E",
    "commandCenter.background": "#1A2028",
    "commandCenter.foreground": "#F2F2F2",
    "commandCenter.border": "#44444E",

    "editorError.foreground": "#E62727",
    "editorWarning.foreground": "#FFD93D",
    "editorInfo.foreground": "#3396D3",
    "editorHint.foreground": "#80D8C3",
    "editorGutter.addedBackground": "#A6B28B",
    "editorGutter.modifiedBackground": "#465C88",
    "editorGutter.deletedBackground": "#B9375D",
    "gitDecoration.addedResourceForeground": "#A6B28B",
    "gitDecoration.modifiedResourceForeground": "#465C88",
    "gitDecoration.deletedResourceForeground": "#B9375D"
  },
  "semanticTokenColors": {
    "comment": "#BFC9D1",
    "keyword": "#FF6B6B",
    "keyword.declaration": "#FAAC68",
    "keyword.flow": "#FFD93D",
    "operator": "#BFC9D1",
    "string": "#6BCB77",
    "number": "#FFD93D",
    "regexp": "#FFD93D",
    "variable": "#F2F2F2",
    "parameter": "#FAAC68",
    "property": "#ABDADC",
    "function": "#4D96FF",
    "method": "#4D96FF",
    "type": "#BB8ED0",
    "class": "#BB8ED0",
    "interface": "#BB8ED0",
    "enum": "#BB8ED0",
    "enumMember": "#FFD93D",
    "namespace": "#FF6B6B",
    "typeParameter": "#FFD93D",
    "variable.readonly": "#FFD93D",
    "property.readonly": "#FFD93D",
    "parameter.readonly": "#FFD93D",
    "variable.defaultLibrary": "#ABDADC"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#BFC9D1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "storage.type.function.js",
        "storage.type.function.ts",
        "keyword.declaration.function",
        "meta.function.js storage.type",
        "meta.function.ts storage.type"
      ],
      "settings": {
        "foreground": "#4D96FF"
      }
    },
    {
      "scope": [
        "keyword.control.flow.return",
        "keyword.control.return",
        "keyword.operator.expression.return"
      ],
      "settings": {
        "foreground": "#FAAC68"
      }
    },
    {
      "scope": [
        "storage.type.var.js",
        "storage.type.let.js",
        "storage.type.const.js",
        "storage.type.var.ts",
        "storage.type.let.ts",
        "storage.type.const.ts",
        "keyword.declaration.var",
        "keyword.declaration.let",
        "keyword.declaration.const"
      ],
      "settings": {
        "foreground": "#FAAC68"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#FF6B6B"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.relational",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#BFC9D1"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "support.function.builtin"
      ],
      "settings": {
        "foreground": "#BB8ED0"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#6BCB77"
      }
    },
    {
      "scope": [
        "string.template",
        "punctuation.definition.string.template",
        "meta.interpolation"
      ],
      "settings": {
        "foreground": "#6BCB77"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#FAAC68"
      }
    },
    {
      "scope": [
        "constant.other.color",
        "constant.regexp",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#FFD93D"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable",
        "identifier"
      ],
      "settings": {
        "foreground": "#F2F2F2"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "variable.other.readwrite.alias"
      ],
      "settings": {
        "foreground": "#FAAC68"
      }
    },
    {
      "scope": [
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#FF6B6B"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#BB8ED0"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FF6B6B"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#FFD93D"
      }
    },
    {
      "scope": [
        "support.type.property-name",
        "variable.object.property",
        "meta.object-literal.key",
        "meta.property-name",
        "entity.name.variable.property"
      ],
      "settings": {
        "foreground": "#ABDADC"
      }
    },
    {
      "scope": [
        "meta.object-literal.key.json",
        "support.type.property-name.json",
        "meta.structure.dictionary.key.json string.quoted.double.json"
      ],
      "settings": {
        "foreground": "#ABDADC"
      }
    },
    {
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#FF6B6B"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.markdown",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#4D96FF",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold",
        "markup.italic"
      ],
      "settings": {
        "foreground": "#F2F2F2",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#FFD93D"
      }
    },
    {
      "scope": [
        "markup.quote",
        "markup.quote.markdown"
      ],
      "settings": {
        "foreground": "#BFC9D1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#BFC9D1"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "meta.link.inline.markdown"
      ],
      "settings": {
        "foreground": "#6BCB77",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "emphasis",
        "entity.name.method.js",
        "entity.name.class.js",
        "entity.name.tag.doctype",
        "entity.other.attribute-name",
        "entity.other.attribute-name.tag.jade",
        "entity.other.attribute-name.tag.pug",
        "italic",
        "markup.italic",
        "markup.quote",
        "markup.changed",
        "markup.italic.markdown",
        "markup.quote.markdown",
        "markup.deleted.diff",
        "markup.inserted.diff",
        "meta.delimiter.period",
        "meta.diff.header.git",
        "meta.diff.header.from-file",
        "meta.diff.header.to-file",
        "meta.tag.sgml.doctype",
        "meta.var.expr",
        "meta.selector",
        "meta.decorator punctuation.decorator",
        "tag.decorator.js entity.name.tag.js",
        "tag.decorator.js"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#222831",
        "background": "#FF6B6B"
      }
    }
  ]
}
